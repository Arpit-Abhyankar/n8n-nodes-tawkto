{
	"name": "n8n-nodes-tawkto",
	"version": "0.1.0",
	"description": "n8n community node for Tawk.to live chat integration - trigger workflows on chat events and interact with the Tawk.to REST API",
	"license": "MIT",
	"homepage": "https://github.com/arpitabhyankar/n8n-nodes-tawkto",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Arpit Abhyankar"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/arpitabhyankar/n8n-nodes-tawkto.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/TawkToApi.credentials.js",
			"dist/credentials/TawkToWebhookApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/TawkTo/TawkTo.node.js",
			"dist/nodes/TawkToTrigger/TawkToTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
